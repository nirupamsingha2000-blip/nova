{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NLI Explain Response",
  "type": "object",
  "required": ["topic","level","style","definition"],
  "properties": {
    "topic": {"type":"string"},
    "level": {"type":"string"},
    "style": {"type":"string"},
    "definition": {"type":"string"},
    "analogy": {"type":"string"},
    "simulation": {
      "type":"object",
      "properties": {"type":{"type":"string"},"url":{"type":"string"},"hint":{"type":"string"}},
      "required": ["type"]
    },
    "commonMistakes": {"type":"array","items":{"type":"string"}},
    "memoryTrick": {"type":"string"},
    "pyq": {"type":"object","properties":{"question":{"type":"string"},"solution":{"type":"string"}}},
    "miniQuiz": {"type":"array","items":{"type":"object","properties":{"id":{"type":"string"},"stem":{"type":"string"},"choices":{"type":"array"},"answer":{},"rationale":{"type":"string"}}}},
    "recommendation": {"type":"string"}
  }
}
